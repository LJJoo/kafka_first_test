# ── 사용법 ────────────────────────────────────────────────────────────────────
# 이 파일을 복사하여 .env 로 저장 후 실제 값을 입력하세요.
#   cp .env.example .env
#
# .env 파일은 두 가지 용도로 사용됩니다.
#   1) IntelliJ 로컬 개발 — Spring Boot 환경변수
#   2) Docker Compose    — docker compose up --build 시 자동 로드
#
# Docker Compose는 DB_HOST / KAFKA_HOST / REDIS_HOST 를 내부적으로
# 서비스명(mysql, kafka, redis)으로 고정하므로 여기서 설정해도 무시됩니다.
# ──────────────────────────────────────────────────────────────────────────────

# ── DB ──────────────────────────────────────────────────
DB_HOST=localhost       # IntelliJ 로컬용 (Docker에서는 무시됨)
DB_NAME=kafka_test
DB_USER=root
DB_PASS=               # 실제 비밀번호 입력

# ── Kafka ────────────────────────────────────────────────
KAFKA_HOST=localhost    # IntelliJ 로컬용 (Docker에서는 무시됨)
                        # VM 사용 시: 192.168.x.x

# ── Redis ────────────────────────────────────────────────
REDIS_HOST=localhost    # IntelliJ 로컬용 (Docker에서는 무시됨)
REDIS_PORT=6379

# ── Kafka 외부 접속 주소 (Docker Compose 전용) ───────────
# docker compose 실행 시 Kafka CLI가 사용할 외부 주소
# 로컬 실행: localhost (기본값 — 설정 불필요)
# ESXi VM 배포: VM의 실제 IP
#   예) KAFKA_EXTERNAL_HOST=192.168.1.100
KAFKA_EXTERNAL_HOST=localhost
